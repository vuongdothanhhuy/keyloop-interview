# This is a monorepo of two sibling npm packages (app/, mock-server/), each
# with its own nested .gitignore for its own build output and node_modules.
# These root-level rules are a safety net that apply at any depth, in case a
# tool writes build artefacts outside those per-package .gitignore scopes.

# Node
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# Build output / caches
dist/
out-tsc/
tmp/
coverage/
.angular/
*.tsbuildinfo

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Environment files
.env
.env.*

# OS
.DS_Store
Thumbs.db
